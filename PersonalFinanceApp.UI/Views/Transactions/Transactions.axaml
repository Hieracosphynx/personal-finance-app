<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PersonalFinanceApp.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:Class="PersonalFinanceApp.UI.Views.Transactions.TransactionsView"
             x:DataType="vm:TransactionsViewModel">

     <StackPanel>
         <Grid ColumnDefinitions="* Auto" Margin="0 0 0 12">
             <TextBlock Grid.Column="0"
                 Text="Transactions"
                 FontSize="20"
                 FontWeight="Bold"/>
             <Button Grid.Column="1"
                 Content="Sync"
                 Command="{Binding SyncCommand}"/>
         </Grid>

         <ListBox ItemsSource="{Binding Transactions}">
             <ListBox.ItemTemplate>
                 <DataTemplate DataType="vm:TransactionViewModel">
                     <Grid ColumnDefinitions="Auto * Auto" Margin="0 4">
                         <TextBlock Grid.Column="0"
                                    Text="{Binding DisplayDate}"
                                    Margin="0 0 12 0"/>
                         <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                         <TextBlock Grid.Column="2" Text="{Binding DisplayAmount}"/>
                     </Grid>
                 </DataTemplate>
             </ListBox.ItemTemplate>
         </ListBox>
     </StackPanel>

</UserControl>
