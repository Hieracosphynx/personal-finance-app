<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PersonalFinanceApp.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PersonalFinanceApp.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Personal Finance"
        Width="800" Height="500">

    <StackPanel Margin="24">

        <Grid ColumnDefinitions="* Auto" Margin="0 0 0 16">
            <TextBlock Grid.Column="0"
                       Text="My Accounts"
                       FontSize="24"
                       FontWeight="Bold"/>
            <Button Grid.Column="1"
                    Content="Sync"
                    Command="{Binding SyncCommand}"/>
        </Grid>
        <ItemsControl ItemsSource="{Binding Accounts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:AccountViewModel">
                    <Grid ColumnDefinitions="* Auto" Margin="0 8">
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayBalance}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</Window>
