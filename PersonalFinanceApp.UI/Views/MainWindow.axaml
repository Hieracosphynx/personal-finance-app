<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PersonalFinanceApp.UI.ViewModels"
        xmlns:accounts="using:PersonalFinanceApp.UI.Views.Accounts"
        xmlns:transactions="using:PersonalFinanceApp.UI.Views.Transactions"
        xmlns:cards="using:PersonalFinanceApp.UI.Views.Cards"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
        x:Class="PersonalFinanceApp.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Personal Finance"
        Background="#0D1117"
        Width="900" Height="800">
    <Grid RowDefinitions="Auto * Auto" Margin="16">
        <Grid Grid.Row="0" ColumnDefinitions="* Auto" Margin="0 0 0 12">
            <TextBlock Grid.Column="0"
                       Text="Personal Finance"
                       FontSize="20"
                       FontWeight="Bold"/>
            <ToggleButton Grid.Column="1"
                          IsChecked="{Binding AmountFormatter.HideAmounts}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="6"
                          ToolTip.Tip="Toggle amount visibility">
                <Panel Width="18" Height="18">
                    <Path IsVisible="{Binding AmountFormatter.ShowAmounts}"
                          Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 
    0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                          Stretch="Uniform"
                          Fill="{DynamicResource SystemBaseHighColor}"/>
                    <Path IsVisible="{Binding AmountFormatter.HideAmounts}"
                          Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 
    3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 
    12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 
    1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 
    3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"
                          Stretch="Uniform"
                          Fill="{DynamicResource SystemBaseHighColor}"/>
                </Panel>
            </ToggleButton>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="260 *">
            <accounts:AccountsView Grid.Column="0" DataContext="{Binding Accounts}"/>
            <transactions:TransactionsView Grid.Column="1" DataContext="{Binding Transactions}"/>
        </Grid>

        <cards:LineGraph Grid.Row="2" DataContext="{Binding LineGraph}"/>
    </Grid>
</Window>
